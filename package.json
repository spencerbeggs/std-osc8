{
	"name": "std-osc8",
	"version": "0.2.0",
	"private": true,
	"description": "Detect terminal hyperlink capabilities of the active terminal from environmental variables",
	"keywords": [
		"osc8",
		"hyperlink",
		"hyperlinks",
		"terminal",
		"tty",
		"ansi",
		"ansi-escape",
		"escape-codes",
		"link",
		"clickable",
		"detection",
		"std-env",
		"cli",
		"console",
		"esm",
		"typescript",
		"iterm",
		"wezterm",
		"kitty",
		"vte",
		"konsole",
		"alacritty",
		"ghostty",
		"vscode-terminal"
	],
	"homepage": "https://github.com/spencerbeggs/std-osc8#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/std-osc8/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/std-osc8.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^2.0.7",
		"@savvy-web/silk": "^3.1.1",
		"@types/node": "catalog:silk",
		"@vitest-agent/plugin": "^2.0.5",
		"typescript": "catalog:silk"
	},
	"packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.5.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/std-osc8"
		}
	}
}
