{
	"name": "std-osc8",
	"version": "0.1.0",
	"private": true,
	"description": "Detect terminal hyperlink capabilities of the active terminal from environmental variables",
	"keywords": [
		"osc8",
		"hyperlink",
		"hyperlinks",
		"terminal",
		"tty",
		"ansi",
		"ansi-escape",
		"escape-codes",
		"link",
		"clickable",
		"detection",
		"std-env",
		"cli",
		"console",
		"esm",
		"typescript",
		"iterm",
		"wezterm",
		"kitty",
		"vte",
		"konsole",
		"alacritty",
		"ghostty",
		"vscode-terminal"
	],
	"homepage": "https://github.com/spencerbeggs/std-osc8#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/std-osc8/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/std-osc8.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.10.1",
		"@savvy-web/commitlint": "^0.10.1",
		"@savvy-web/lint-staged": "^1.2.1",
		"@savvy-web/rslib-builder": "^0.20.12",
		"@savvy-web/vitest": "^1.3.2"
	},
	"packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.34.1",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.2.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
